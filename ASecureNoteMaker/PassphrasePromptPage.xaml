<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ASecureNoteMaker.PassphrasePromptPage"
             Title=""
             BackgroundColor="#80000000">

    <Grid>
        <!-- Modal card centered on screen -->
        <Border HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="380"
                Stroke="#e2e8f0"
                StrokeThickness="1"
                BackgroundColor="White"
                Padding="28">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,8" Radius="24" Opacity="0.15" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="20">
                <!-- Icon + Title -->
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label Text="&#128274;"
                           FontSize="36"
                           HorizontalOptions="Center" />
                    <Label Text="Enter Passphrase"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#1e293b"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Prompt text -->
                <Label x:Name="PromptLabel"
                       Text="Enter the passphrase for this file."
                       TextColor="#64748b"
                       FontSize="14"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />

                <!-- Password entry -->
                <Border Stroke="#e2e8f0"
                        StrokeThickness="1"
                        BackgroundColor="#f8fafc"
                        Padding="4,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Entry x:Name="PassphraseEntry"
                           IsPassword="True"
                           Placeholder="Passphrase"
                           PlaceholderColor="#94a3b8"
                           TextColor="#1e293b"
                           FontSize="16"
                           BackgroundColor="Transparent"
                           ReturnCommand="{Binding ConfirmCommand}"
                           ReturnType="Done" />
                </Border>

                <!-- Show/Hide toggle -->
                <HorizontalStackLayout Spacing="8">
                    <CheckBox x:Name="ShowPassphraseCheckbox"
                              Color="#4f46e5"
                              CheckedChanged="OnShowPassphraseChanged" />
                    <Label Text="Show passphrase"
                           TextColor="#64748b"
                           FontSize="14"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Buttons -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="12" Margin="0,4,0,0">
                    <Button Grid.Column="0"
                            Text="Cancel"
                            BackgroundColor="Transparent"
                            TextColor="#4f46e5"
                            BorderColor="#4f46e5"
                            BorderWidth="1"
                            CornerRadius="8"
                            MinimumHeightRequest="44"
                            Clicked="OnCancelClicked" />
                    <Button Grid.Column="1"
                            x:Name="ConfirmButton"
                            Text="Unlock"
                            BackgroundColor="#4f46e5"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            MinimumHeightRequest="44"
                            Clicked="OnOkClicked" />
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
